# Environment Configuration Template

# Copy this file to create your own .env for local testing
# Source it before running DAB commands

# Databricks Workspace Configuration
export DATABRICKS_HOST="https://your-workspace.cloud.databricks.com"
export DATABRICKS_TOKEN="your-personal-access-token"

# AWS S3 Configuration
export BATCH_S3_BUCKET="lambda-arch-batch-YOUR-ACCOUNT-ID"
export STREAMING_S3_BUCKET="lambda-arch-streaming-YOUR-ACCOUNT-ID"

# Kinesis Configuration
export KINESIS_STREAM_NAME="lambda-arch-events"

# Instance Pool (Optional - leave empty for on-demand)
export INSTANCE_POOL_ID=""

# Optional: AWS Region
export AWS_REGION="us-east-1"
